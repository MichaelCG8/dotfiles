#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: rcf <start-rev> [<end-rev>]

Interactive forward review from <start-rev> to <end-rev> (default: HEAD)
along first-parent history.

Controls:
  n           next commit
  p           previous commit
  d           show diff
  o           open changed file in editor
  f           fast-forward start ref to current commit
  q           quit
  h           help
EOF
}

if [[ "${1:-}" == "" || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

start_rev="$1"
end_rev="${2:-HEAD}"

git rev-parse --git-dir >/dev/null 2>&1 || {
  echo "Not a git repository." >&2
  exit 1
}

start_sha="$(git rev-parse --verify "${start_rev}^{commit}" 2>/dev/null || true)"
if [[ -z "$start_sha" ]]; then
  echo "Could not resolve '${start_rev}' to a commit." >&2
  exit 1
fi

# Detect if start_rev is a branch or tag (enables the 'f' fast-forward command).
# ref_current_sha tracks where the ref currently points, updated after each ff.
# If start_rev is a raw SHA or other non-ref, start_ref_type stays empty and ff is disabled.
start_ref_name=""
start_ref_type=""
if git show-ref --verify "refs/heads/${start_rev}" >/dev/null 2>&1; then
  start_ref_name="$start_rev"
  start_ref_type="BRANCH"
elif git show-ref --verify "refs/tags/${start_rev}" >/dev/null 2>&1; then
  start_ref_name="$start_rev"
  start_ref_type="TAG"
fi
ref_current_sha="$start_sha"

end_ref_name=""
end_ref_type=""
if git show-ref --verify "refs/heads/${end_rev}" >/dev/null 2>&1; then
  end_ref_name="$end_rev"
  end_ref_type="BRANCH"
elif git show-ref --verify "refs/tags/${end_rev}" >/dev/null 2>&1; then
  end_ref_name="$end_rev"
  end_ref_type="TAG"
fi

# Warn during ff if start and end are both branches but different names (e.g. main vs feature).
# This is usually unintentional — ff is designed for local/remote pairs or tag-to-branch reviews.
ff_cross_branch=false
if [[ "$start_ref_type" == "BRANCH" && "$end_ref_type" == "BRANCH" && "$start_ref_name" != "$end_ref_name" ]]; then
  ff_cross_branch=true
fi

end_sha="$(git rev-parse --verify "${end_rev}^{commit}" 2>/dev/null || true)"
if [[ -z "$end_sha" ]]; then
  echo "Could not resolve '${end_rev}' to a commit." >&2
  exit 1
fi

if ! git merge-base --is-ancestor "$start_sha" "$end_sha"; then
  echo "Start commit is not an ancestor of ${end_rev}." >&2
  exit 1
fi

# Build commit list (bash 3 compatible)
commits=()
while IFS= read -r sha; do
  commits+=( "$sha" )
done < <(git rev-list --first-parent --reverse "${start_sha}..${end_sha}")

total="${#commits[@]}"

if (( total == 0 )); then
  echo "No commits to review between ${start_rev} and ${end_rev}."
  exit 0
fi

print_commit_info() {
  local idx="$1"
  local sha="${commits[$idx]}"
  local num=$((idx + 1))

  clear
  echo "============================================================"
  echo "${num}/${total}  $(git rev-parse --short "$sha")"
  echo "------------------------------------------------------------"
  git show -s \
    --format=$'Date: %ad%nAuthor: %an <%ae>%n%n%B' \
    --date=iso-strict \
    "$sha"
  echo "------------------------------------------------------------"
  git diff-tree --stat "$sha"
  echo "============================================================"
  echo

  if (( idx == total - 1 )); then
    echo "You are at the last commit. Press 'd' to view diff, or 'q' to quit."
    echo
  fi
}

open_file() {
  local sha="$1"
  local files=()
  while IFS= read -r f; do
    files+=("$f")
  done < <(git diff-tree --no-commit-id -r --name-only "$sha")

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "No files changed in this commit."
    return
  fi

  local selected=0
  local count=${#files[@]}
  local repo_root
  repo_root="$(git rev-parse --show-toplevel)"

  draw_list() {
    for (( i = 0; i < count; i++ )); do
      if (( i == selected )); then
        printf "\r\033[K\033[7m %s \033[m\n" "${files[$i]}"
      else
        printf "\r\033[K  %s\n" "${files[$i]}"
      fi
    done
  }

  echo "Select file to open (↑↓=navigate, Enter=open, q=cancel):"
  tput civis
  draw_list

  while true; do
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
      IFS= read -rsn1 -t 1 seq1 || true
      IFS= read -rsn1 -t 1 seq2 || true
      case "${seq1}${seq2}" in
        '[A') if (( selected > 0 )); then selected=$((selected - 1)); fi ;;
        '[B') if (( selected < count - 1 )); then selected=$((selected + 1)); fi ;;
      esac
      tput cuu "$count"
      draw_list
    elif [[ "$key" == '' ]]; then
      tput cnorm
      local tmpdir tmpfile
      tmpdir="$(mktemp -d /tmp/rcf-XXXXXX)"
      tmpfile="${tmpdir}/$(basename "${files[$selected]}")"
      if git show "${sha}:${files[$selected]}" > "$tmpfile" 2>/dev/null; then
        : # file existed at this commit
      elif git show "${sha}^:${files[$selected]}" > "$tmpfile" 2>/dev/null; then
        : # file was deleted in this commit, show pre-deletion content
      else
        rm -rf "$tmpdir"
        echo "Could not retrieve file content from git."
        return
      fi
      chmod 444 "$tmpfile"
      chmod 555 "$tmpdir"
      local editor="${VISUAL:-${EDITOR:-vi}}"
      case "$(basename "$editor")" in
        vi|vim|nvim)  "$editor" -M "$tmpfile" ;;
        nano)         "$editor" --view "$tmpfile" ;;
        emacs|emacs*) "$editor" --eval "(view-mode 1)" "$tmpfile" ;;
        *)            "$editor" "$tmpfile" ;;
      esac
      chmod 755 "$tmpdir"
      rm -rf "$tmpdir"
      return
    elif [[ "$key" == 'q' ]]; then
      tput cnorm
      return
    fi
  done
}

show_diff() {
  local sha="$1"
  echo
  echo "Press 'q' to exit diff and return to review"
  echo

  if git rev-parse --verify "${sha}^" >/dev/null 2>&1; then
    git diff "${sha}^" "$sha" | delta --paging=always
  else
    git show --format= "$sha" | delta --paging=always
  fi
}

# Fast-forward the start ref (branch or tag) to the given commit.
# Uses --ff-only semantics: only advances if target is a descendant of current position.
# For branches, uses update-ref with the old sha as a guard against concurrent changes.
# For tags, uses tag -f to overwrite in place.
ff_ref() {
  local target_sha="$1"

  if [[ -z "$start_ref_type" ]]; then
    echo "Cannot fast-forward: start-rev is not a branch or tag."
    return 1
  fi

  if [[ "$target_sha" == "$ref_current_sha" ]]; then
    echo "${start_ref_type} '${start_ref_name}' already points at this commit."
    return 1
  fi

  if ! git merge-base --is-ancestor "$ref_current_sha" "$target_sha"; then
    echo "Cannot fast-forward: current commit is not a descendant of ${start_ref_type} '${start_ref_name}'."
    return 1
  fi

  local old_short old_subject new_short new_subject
  old_short="$(git rev-parse --short "$ref_current_sha")"
  old_subject="$(git show -s --format='%s' "$ref_current_sha")"
  new_short="$(git rev-parse --short "$target_sha")"
  new_subject="$(git show -s --format='%s' "$target_sha")"

  echo
  if [[ "$ff_cross_branch" == true ]]; then
    printf "\033[1;33mWARNING: FAST-FORWARDING ACROSS DIFFERENT BRANCHES\033[m\n"
    printf "  start: %s   end: %s\n" "$start_ref_name" "$end_ref_name"
    echo
  fi
  printf "Fast-forward %s \033[1m'%s'\033[m ?\n" "$start_ref_type" "$start_ref_name"
  echo "  from: ${old_short} ${old_subject}"
  echo "  to:   ${new_short} ${new_subject}"
  echo
  printf "Confirm? [y/N] "
  IFS= read -r answer
  if [[ "$answer" == "y" || "$answer" == "Y" ]]; then
    if [[ "$start_ref_type" == "BRANCH" ]]; then
      git update-ref "refs/heads/${start_ref_name}" "$target_sha" "$ref_current_sha"
    else
      git tag -f "$start_ref_name" "$target_sha" >/dev/null 2>&1
    fi
    ref_current_sha="$target_sha"
    echo "${start_ref_type} '${start_ref_name}' updated to ${new_short}."
  else
    echo "Cancelled."
    return 1
  fi
}

idx=0
print_commit_info "$idx"

while true; do
  printf "Command [d=diff, o=open, f=ff, n=next, p=prev, q=quit, h=help]: "
  IFS= read -r cmd || exit 0

  case "$cmd" in
    d)
      show_diff "${commits[$idx]}"
      print_commit_info "$idx"
      ;;
    o)
      open_file "${commits[$idx]}"
      print_commit_info "$idx"
      ;;
    f)
      if ff_ref "${commits[$idx]}"; then
        print_commit_info "$idx"
      fi
      ;;
    "")
      ;;  # do nothing on bare Enter
    n)
      if (( idx < total - 1 )); then
        idx=$((idx + 1))
        print_commit_info "$idx"
      else
        echo "Already at the last commit. Use 'd' to view diff or 'q' to quit."
      fi
      ;;
    p)
      if (( idx > 0 )); then
        idx=$((idx - 1))
        print_commit_info "$idx"
      else
        echo "Already at first commit."
      fi
      ;;
    q)
      echo "Quitting."
      exit 0
      ;;
    h|\?)
      usage
      ;;
    *)
      echo "Unknown command: '$cmd'"
      ;;
  esac
done
