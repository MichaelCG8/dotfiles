#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: rcf <start-rev> [<end-rev>]

Interactive forward review from <start-rev> to <end-rev> (default: HEAD)
along first-parent history.

Controls:
  n           next commit
  p           previous commit
  d           show diff
  o           open changed file in editor
  q           quit
  h           help
EOF
}

if [[ "${1:-}" == "" || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

start_rev="$1"
end_rev="${2:-HEAD}"

git rev-parse --git-dir >/dev/null 2>&1 || {
  echo "Not a git repository." >&2
  exit 1
}

start_sha="$(git rev-parse --verify "${start_rev}^{commit}" 2>/dev/null || true)"
if [[ -z "$start_sha" ]]; then
  echo "Could not resolve '${start_rev}' to a commit." >&2
  exit 1
fi

end_sha="$(git rev-parse --verify "${end_rev}^{commit}" 2>/dev/null || true)"
if [[ -z "$end_sha" ]]; then
  echo "Could not resolve '${end_rev}' to a commit." >&2
  exit 1
fi

if ! git merge-base --is-ancestor "$start_sha" "$end_sha"; then
  echo "Start commit is not an ancestor of ${end_rev}." >&2
  exit 1
fi

# Build commit list (bash 3 compatible)
commits=()
while IFS= read -r sha; do
  commits+=( "$sha" )
done < <(git rev-list --first-parent --reverse "${start_sha}..${end_sha}")

total="${#commits[@]}"

print_commit_info() {
  local idx="$1"
  local sha="${commits[$idx]}"
  local num=$((idx + 1))

  clear
  echo "============================================================"
  echo "${num}/${total}  $(git rev-parse --short "$sha")"
  echo "------------------------------------------------------------"
  git show -s \
    --format=$'Date: %ad%nAuthor: %an <%ae>%n%n%B' \
    --date=iso-strict \
    "$sha"
  echo "------------------------------------------------------------"
  git diff-tree --stat "$sha"
  echo "============================================================"
  echo

  if (( idx == total - 1 )); then
    echo "You are at the last commit. Press 'd' to view diff, or 'q' to quit."
    echo
  fi
}

open_file() {
  local sha="$1"
  local files=()
  while IFS= read -r f; do
    files+=("$f")
  done < <(git diff-tree --no-commit-id -r --name-only "$sha")

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "No files changed in this commit."
    return
  fi

  local selected=0
  local count=${#files[@]}
  local repo_root
  repo_root="$(git rev-parse --show-toplevel)"

  draw_list() {
    for (( i = 0; i < count; i++ )); do
      if (( i == selected )); then
        printf "\r\033[K\033[7m %s \033[m\n" "${files[$i]}"
      else
        printf "\r\033[K  %s\n" "${files[$i]}"
      fi
    done
  }

  echo "Select file to open (↑↓=navigate, Enter=open, q=cancel):"
  tput civis
  draw_list

  while true; do
    IFS= read -rsn1 key
    if [[ "$key" == $'\x1b' ]]; then
      IFS= read -rsn1 -t 1 seq1 || true
      IFS= read -rsn1 -t 1 seq2 || true
      case "${seq1}${seq2}" in
        '[A') if (( selected > 0 )); then selected=$((selected - 1)); fi ;;
        '[B') if (( selected < count - 1 )); then selected=$((selected + 1)); fi ;;
      esac
      tput cuu "$count"
      draw_list
    elif [[ "$key" == '' ]]; then
      tput cnorm
      local tmpdir tmpfile
      tmpdir="$(mktemp -d /tmp/rcf-XXXXXX)"
      tmpfile="${tmpdir}/$(basename "${files[$selected]}")"
      if git show "${sha}:${files[$selected]}" > "$tmpfile" 2>/dev/null; then
        : # file existed at this commit
      elif git show "${sha}^:${files[$selected]}" > "$tmpfile" 2>/dev/null; then
        : # file was deleted in this commit, show pre-deletion content
      else
        rm -rf "$tmpdir"
        echo "Could not retrieve file content from git."
        return
      fi
      chmod 444 "$tmpfile"
      chmod 555 "$tmpdir"
      local editor="${VISUAL:-${EDITOR:-vi}}"
      case "$(basename "$editor")" in
        vi|vim|nvim)  "$editor" -M "$tmpfile" ;;
        nano)         "$editor" --view "$tmpfile" ;;
        emacs|emacs*) "$editor" --eval "(view-mode 1)" "$tmpfile" ;;
        *)            "$editor" "$tmpfile" ;;
      esac
      chmod 755 "$tmpdir"
      rm -rf "$tmpdir"
      return
    elif [[ "$key" == 'q' ]]; then
      tput cnorm
      return
    fi
  done
}

show_diff() {
  local sha="$1"
  echo
  echo "Press 'q' to exit diff and return to review"
  echo

  if git rev-parse --verify "${sha}^" >/dev/null 2>&1; then
    git diff "${sha}^" "$sha" | delta --paging=always
  else
    git show --format= "$sha" | delta --paging=always
  fi
}

idx=0
print_commit_info "$idx"

while true; do
  printf "Command [d=diff, o=open, n=next, p=prev, q=quit, h=help]: "
  IFS= read -r cmd || exit 0

  case "$cmd" in
    d)
      show_diff "${commits[$idx]}"
      print_commit_info "$idx"
      ;;
    o)
      open_file "${commits[$idx]}"
      print_commit_info "$idx"
      ;;
    "")
      ;;  # do nothing on bare Enter
    n)
      if (( idx < total - 1 )); then
        idx=$((idx + 1))
        print_commit_info "$idx"
      else
        echo "Already at the last commit. Use 'd' to view diff or 'q' to quit."
      fi
      ;;
    p)
      if (( idx > 0 )); then
        idx=$((idx - 1))
        print_commit_info "$idx"
      else
        echo "Already at first commit."
      fi
      ;;
    q)
      echo "Quitting."
      exit 0
      ;;
    h|\?)
      usage
      ;;
    *)
      echo "Unknown command: '$cmd'"
      ;;
  esac
done
